<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- 模式切换，居中显示 -->
    <RadioGroup
        android:id="@+id/modeGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:checkedButton="@id/modeText">
        <RadioButton
            android:id="@+id/modeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="文本模式"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />
        <RadioButton
            android:id="@+id/modePath"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="文件夹模式"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />
    </RadioGroup>

    <!-- 文件夹模式区域（默认隐藏） -->
    <LinearLayout
        android:id="@+id/pathLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:layout_marginTop="12dp">
        <EditText
            android:id="@+id/inputPath"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="输入文件夹路径，如 /storage/emulated/0/压缩/"
            android:inputType="textUri"
            android:singleLine="true" />
        <Button
            android:id="@+id/generateTreeBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="生成文件树" />
    </LinearLayout>

    <!-- 文本编辑区域 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="输入文件树（目录以“/”结尾）"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/inputTree"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="top|start"
        android:inputType="textMultiLine|textNoSuggestions"
        android:hint="在此粘贴树形结构，或从文件夹模式生成..."
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:background="@android:drawable/edit_text" />

    <!-- 生成 ZIP 按钮 -->
    <Button
        android:id="@+id/generateBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="生成 ZIP 并保存到内部存储" />

</LinearLayout>        <EditText
            android:id="@+id/inputPath"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="输入文件夹路径，如 /storage/emulated/0/压缩/"
            android:inputType="textUri"
            android:singleLine="true" />
        <Button
            android:id="@+id/generateTreeBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="生成文件树" />
    </LinearLayout>

    <!-- 文本编辑区域 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="输入文件树（目录以“/”结尾）"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/inputTree"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="top|start"
        android:inputType="textMultiLine|textNoSuggestions"
        android:hint="在此粘贴树形结构，或从文件夹模式生成..."
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:background="@android:drawable/edit_text" />

    <!-- 生成 ZIP 按钮 -->
    <Button
        android:id="@+id/generateBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="生成 ZIP 并保存到内部存储" />

</LinearLayout>
